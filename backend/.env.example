# ─────────────────────────────────────────────
#  Renta Form – Backend environment variables
#  Copy this file to .env and edit as needed.
# ─────────────────────────────────────────────

# Profile: "db" (PostgreSQL, default)
PROFILE=db

# Server port (default: 3001)
PORT=3001

# ── PostgreSQL connection ─────────────────────
# Connection URL (recommended for Heroku / Neon)
# Replace the placeholder below with your actual database credentials.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
PG_SSL_REJECT_UNAUTHORIZED=false

# ── CORS origin (comma-separated, default: http://localhost:5173) ──
CORS_ORIGIN=http://localhost:5173

# ── Admin credentials ──
ADMIN_PASSWORD=admin
