# ─────────────────────────────────────────────
#  Renta Form – Backend environment variables
#  Copy this file to .env and edit as needed.
# ─────────────────────────────────────────────

# Profile: "mock" (in-memory, default) or "db" (PostgreSQL)
PROFILE=mock

# Server port (default: 3001)
PORT=3001

# ── PostgreSQL (only used when PROFILE=db) ────
PGHOST=localhost
PGPORT=5432
PGDATABASE=renta_form
PGUSER=postgres
PGPASSWORD=postgres

# ── CORS origin (comma-separated, default: http://localhost:5173) ──
CORS_ORIGIN=http://localhost:5173

# ── Admin credentials (only for the mock profile) ──
ADMIN_PASSWORD=admin
