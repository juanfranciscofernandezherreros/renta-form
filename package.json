{
  "name": "renta-form",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "test": "cucumber-js",
    "test:api": "cucumber-js --profile api",
    "generate": "openapi-ts",
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "serve -s dist",
    "start:backend": "cd backend && npm start",
    "start:db": "cd backend && npm run start:db",
    "migrate": "cd backend && npm run migrate",
    "seed": "cd backend && npm run seed",
    "db:setup": "cd backend && npm run db:setup",
    "db:setup-100": "cd backend && npm run db:setup-100",
    "db:seed-translations": "cd backend && npm run db:seed-translations",
    "db:seed-languages": "cd backend && npm run db:seed-languages",
    "db:seed-100": "cd backend && npm run db:seed-100",
    "heroku-postbuild": "npm install --prefix backend && npm run build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.13.1",
    "jspdf": "^4.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "serve": "^14.2.6",
    "swagger-ui-react": "^5.32.2"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^11.3.0",
    "@eslint/js": "^9.39.4",
    "@hey-api/openapi-ts": "^0.95.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "playwright": "^1.55.1",
    "vite": "^8.0.4"
  }
}
