# ─────────────────────────────────────────────
#  Renta Form – Backend environment variables
#  Copy this file to .env and edit as needed.
# ─────────────────────────────────────────────

# Profile: "mock" (in-memory) or "db" (PostgreSQL, default)
PROFILE=db

# Server port (default: 3001)
PORT=3001

# ── PostgreSQL connection ─────────────────────
# Option A: single connection URL (recommended for Heroku / Neon)
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# PG_SSL_REJECT_UNAUTHORIZED=false  # set only for self-signed certs in local dev

# Option B: individual variables (used only when DATABASE_URL is not set)
PGHOST=localhost
PGPORT=5432
PGDATABASE=renta_form
PGUSER=postgres
PGPASSWORD=postgres

# ── CORS origin (comma-separated, default: http://localhost:5173) ──
CORS_ORIGIN=http://localhost:5173

# ── Admin credentials (only for the mock profile) ──
ADMIN_PASSWORD=admin
